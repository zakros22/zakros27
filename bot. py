import os
import telebot
import re
import tempfile
import subprocess
import time
from datetime import datetime
from gtts import gTTS
from PIL import Image, ImageDraw, ImageFont
from moviepy.editor import ImageClip, AudioFileClip, concatenate_videoclips

BOT_TOKEN = os.environ.get("BOT_TOKEN")
if not BOT_TOKEN:
    raise Exception("BOT_TOKEN not set")

bot = telebot.TeleBot(BOT_TOKEN)

# مجلد مؤقت
TEMP_DIR = tempfile.mkdtemp()

def split_text(text, max_chars=300):
    """تقسيم النص إلى أجزاء قصيرة (كل جزء 300 حرف) لإنشاء شرائح متعددة"""
    sentences = re.split(r'(?<=[.!?]) +', text)
    chunks = []
    current = ""
    for sent in sentences:
        if len(current) + len(sent) + 1 <= max_chars:
            current += " " + sent if current else sent
        else:
            if current:
                chunks.append(current)
            current = sent
    if current:
        chunks.append(current)
    return chunks if chunks else [text[:max_chars]]

def create_slide(text, index, output_path):
    """إنشاء صورة شريحة بخلفية مناسبة ونص"""
    width, height = 1280, 720
    img = Image.new('RGB', (width, height), color=(20, 30, 60))  # خلفية زرقاء داكنة
    draw = ImageDraw.Draw(img)
    
    # استخدام خط افتراضي (يمكن تغييره لاحقاً)
    try:
        font = ImageFont.truetype("/usr/share/fonts/truetype/dejavu/DejaVuSans.ttf", 48)
    except:
        font = ImageFont.load_default()
    
    # تقسيم النص إلى أسطر (كل سطر بحد أقصى 30 حرفاً)
    words = text.split()
    lines = []
    line = ""
    for w in words:
        if len(line + " " + w) <= 30:
            line += " " + w if line else w
        else:
            lines.append(line)
            line = w
    if line:
        lines.append(line)
    
    y = 200
    for line in lines:
        draw.text((100, y), line, fill=(255, 255, 255), font=font)
        y += 70
    
    # إضافة رقم الشريحة
    draw.text((1150, 650), f"{index}", fill=(200, 200, 200), font=font)
    
    img.save(output_path)

def text_to_video(full_text, output_video):
    """تحويل النص الكامل إلى فيديو (صوت + شرائح)"""
    # 1. تقسيم النص إلى شرائح
    chunks = split_text(full_text, max_chars=280)
    if len(chunks) > 15:
        chunks = chunks[:15]  # حد أقصى 15 شريحة لتجنب طول الفيديو
    print(f"عدد الشرائح: {len(chunks)}")
    
    # 2. إنشاء الشرائح كصور
    slide_paths = []
    for i, chunk in enumerate(chunks):
        img_path = os.path.join(TEMP_DIR, f"slide_{i}.png")
        create_slide(chunk, i+1, img_path)
        slide_paths.append(img_path)
    
    # 3. تحويل النص الكامل إلى صوت (gTTS)
    audio_path = os.path.join(TEMP_DIR, "audio.mp3")
    tts = gTTS(text=full_text[:3500], lang='ar', slow=False)  # حد أقصى 3500 حرف للصوت
    tts.save(audio_path)
    audio = AudioFileClip(audio_path)
    audio_duration = audio.duration
    
    # 4. حساب مدة كل شريحة (توزيع متساوٍ)
    duration_per_slide = audio_duration / len(slide_paths)
    clips = []
    for img_path in slide_paths:
        clip = ImageClip(img_path).set_duration(duration_per_slide).resize(height=720)
        clips.append(clip)
    
    # 5. دمج الشرائح والصوت
    final_video = concatenate_videoclips(clips, method="compose")
    final_video = final_video.set_audio(audio)
    final_video.write_videofile(output_video, fps=24, codec='libx264', audio_codec='aac', threads=2, preset='ultrafast')
    
    return output_video

@bot.message_handler(commands=['start'])
def start_cmd(message):
    bot.send_message(message.chat.id,
        "🎥 أرسل لي نصًا (أو ملف .txt) وسأحوله إلى فيديو تعليمي.\n\n"
        "📌 ملاحظات:\n"
        "- الحد الأقصى للنص: 3000 حرف\n"
        "- الفيديو سيحتوي على شرائح نصية + صوت مركب\n"
        "- قد يستغرق التحويل دقيقة أو أكثر حسب طول النص")

@bot.message_handler(content_types=['text'])
def handle_text(message):
    text = message.text.strip()
    if len(text) < 50:
        bot.reply_to(message, "❌ النص قصير جدًا (يحتاج على الأقل 50 حرفًا).")
        return
    if len(text) > 3000:
        bot.reply_to(message, "❌ النص طويل جدًا (الحد الأقصى 3000 حرف).")
        return
    
    msg = bot.reply_to(message, "⏳ جاري تحويل النص إلى فيديو... قد يستغرق 1-2 دقيقة.")
    try:
        out_file = os.path.join(TEMP_DIR, f"video_{datetime.now().strftime('%Y%m%d_%H%M%S')}.mp4")
        text_to_video(text, out_file)
        
        with open(out_file, 'rb') as f:
            bot.send_video(message.chat.id, f, caption="✅ تم إنشاء الفيديو بنجاح!", supports_streaming=True)
        
        # تنظيف
        os.remove(out_file)
        for f in os.listdir(TEMP_DIR):
            if f.endswith(('.png', '.mp3')):
                os.remove(os.path.join(TEMP_DIR, f))
    except Exception as e:
        bot.edit_message_text(f"❌ حدث خطأ: {str(e)[:200]}", message.chat.id, msg.message_id)

@bot.message_handler(content_types=['document'])
def handle_doc(message):
    if message.document.mime_type != 'text/plain':
        bot.reply_to(message, "❌ يرجى إرسال ملف نصي بصيغة .txt فقط.")
        return
    try:
        file_info = bot.get_file(message.document.file_id)
        downloaded = bot.download_file(file_info.file_path)
        text = downloaded.decode('utf-8')
        if len(text) > 3000:
            bot.reply_to(message, "❌ الملف كبير جدًا (الحد الأقصى 3000 حرف).")
            return
        if len(text) < 50:
            bot.reply_to(message, "❌ الملف قصير جدًا.")
            return
        msg = bot.reply_to(message, "⏳ جاري تحويل الملف إلى فيديو...")
        out_file = os.path.join(TEMP_DIR, f"video_{datetime.now().strftime('%Y%m%d_%H%M%S')}.mp4")
        text_to_video(text, out_file)
        with open(out_file, 'rb') as f:
            bot.send_video(message.chat.id, f, caption="✅ تم تحويل الملف النصي إلى فيديو!", supports_streaming=True)
        os.remove(out_file)
    except Exception as e:
        bot.reply_to(message, f"❌ فشل المعالجة: {str(e)[:200]}")

