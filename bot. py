def run_child(token, username):
    ch = get_channel()
    code = generate_child_code(token, username, OWNER_ID, ch["link"], ch["username"])
    os.makedirs("child_bots", exist_ok=True)
    filename = f"child_bots/{username}.py"
    with open(filename, "w", encoding="utf-8") as f:
        f.write(code)
    subprocess.Popen(["python", filename])

# ========== أوامر البوت الرئيسي ==========
@main_bot.message_handler(commands=['start'])
def start_main(m):
    uid = m.chat.id
    create_user(uid)
    markup = InlineKeyboardMarkup()
    markup.add(InlineKeyboardButton("➕ صنع بوت", callback_data="new"), InlineKeyboardButton("📋 بوتاتي", callback_data="list"))
    if uid == OWNER_ID:
        markup.add(InlineKeyboardButton("⚙️ لوحة التحكم", callback_data="admin"))
    main_bot.send_message(uid, "مرحباً بك في مصنع البوتات", reply_markup=markup)

@main_bot.callback_query_handler(func=lambda call: True)
def main_callback(call):
    uid = call.message.chat.id
    data = call.data
    if data == "new":
        ch = get_channel()
        if ch["link"] and not is_subscribed(uid, ch["username"]):
            mk = InlineKeyboardMarkup()
            mk.add(InlineKeyboardButton("اشترك", url=ch["link"]), InlineKeyboardButton("تحقق", callback_data="verify_new"))
            main_bot.send_message(uid, f"اشترك أولاً: {ch['link']}", reply_markup=mk)
            return
        user = get_user(uid)
        if uid != OWNER_ID and (not user or len(user["created_bots"]) >= user["bots_limit"] or not user["can_create"]):
            main_bot.answer_callback_query(call.id, "غير مسموح", show_alert=True)
            return
        main_bot.send_message(uid, "أرسل توكن البوت الجديد (من @BotFather):")
        main_bot.register_next_step_handler(call.message, process_token)
    elif data == "list":
        user = get_user(uid)
        if not user or not user["created_bots"]:
            main_bot.send_message(uid, "ليس لديك أي بوتات.")
            return
        txt = "بوتاتك:\n"
        for b in user["created_bots"]:
            txt += f"- @{b['username']}\n"
        main_bot.send_message(uid, txt)
    elif data == "admin" and uid == OWNER_ID:
        show_admin(uid)
    elif data == "verify_new":
        ch = get_channel()
        if is_subscribed(uid, ch["username"]):
            main_bot.answer_callback_query(call.id, "تم التحقق")
            main_bot.edit_message_reply_markup(uid, call.message.message_id, reply_markup=None)
            main_bot.send_message(uid, "أرسل توكن البوت الجديد:")
            main_bot.register_next_step_handler(call.message, process_token)
        else:
            main_bot.answer_callback_query(call.id, "لم تشترك بعد", show_alert=True)

def process_token(m):
    token = m.text.strip().replace(" ", "")
    try:
        test = telebot.TeleBot(token)
        me = test.get_me()
        add_bot(m.chat.id, token, me.username)
        run_child(token, me.username)
        main_bot.send_message(m.chat.id, f"✅ تم إنشاء وتشغيل البوت @{me.username}")
    except Exception as e:
        main_bot.send_message(m.chat.id, f"❌ فشل: {str(e)[:200]}")

def show_admin(uid):
    ch = get_channel()
    status = f"القناة: {ch['link']}" if ch['link'] else "لا توجد قناة محددة"
    markup = InlineKeyboardMarkup()
    markup.add(InlineKeyboardButton("🔗 تعيين قناة", callback_data="admin_set_ch"))
    markup.add(InlineKeyboardButton("📋 جميع البوتات", callback_data="admin_list"))
    markup.add(InlineKeyboardButton("🗑️ إزالة حقوق بوت", callback_data="admin_rm"))
    markup.add(InlineKeyboardButton("➕ السماح لمستخدم", callback_data="admin_allow"))
    markup.add(InlineKeyboardButton("🚫 منع مستخدم", callback_data="admin_block"))
    markup.add(InlineKeyboardButton("📢 بث", callback_data="admin_broad"))
    main_bot.send_message(uid, f"لوحة التحكم\n{status}", reply_markup=markup)

@main_bot.callback_query_handler(func=lambda call: call.data.startswith("admin_"))
def admin_actions(call):
    uid = call.message.chat.id
    if uid != OWNER_ID:
        return
    act = call.data.split("_")[1]
    if act == "set_ch":
        main_bot.send_message(uid, "أرسل رابط القناة (مثال: https://t.me/username):")
        main_bot.register_next_step_handler(call.message, set_channel_step)
    elif act == "list":
        conn = sqlite3.connect(DB_NAME)
        c = conn.cursor()
        c.execute("SELECT username, owner_id FROM bots")
        rows = c.fetchall()
        conn.close()
        if not rows:
            main_bot.send_message(uid, "لا توجد بوتات.")
            return
        txt = "قائمة البوتات:\n"
        for un, oid in rows:
            txt += f"@{un} (المالك: {oid})\n"
        main_bot.send_message(uid, txt)
    elif act == "rm":
        main_bot.send_message(uid, "أرسل معرف البوت (username بدون @):")
        main_bot.register_next_step_handler(call.message, remove_rights_step)
    elif act == "allow":
        main_bot.send_message(uid, "أرسل ID المستخدم:")
        main_bot.register_next_step_handler(call.message, allow_user_step)
    elif act == "block":
        main_bot.send_message(uid, "أرسل ID المستخدم:")
        main_bot.register_next_step_handler(call.message, block_user_step)
    elif act == "broad":
        main_bot.send_message(uid, "أرسل الرسالة التي تريد بثها:")
        main_bot.register_next_step_handler(call.message, broadcast_step)

def set_channel_step(m):
    link = m.text.strip()
    match = re.search(r't\.me/([A-Za-z0-9_]+)', link)
    if not match:
        main_bot.send_message(OWNER_ID, "❌ رابط غير صالح.")
        return
    uname = match.group(1)
    set_channel(link, uname)
    main_bot.send_message(OWNER_ID, f"✅ تم تعيين القناة: {link}\nمعرف القناة: @{uname}")

def remove_rights_step(m):
    uname = m.text.strip().replace("@", "")
    main_bot.send_message(OWNER_ID, f"✅ تم إزالة الحقوق من @{uname} (يمكنك إعادة تشغيل البوت إذا أردت تطبيقياً)")

def allow_user_step(m):
    try:
        uid = int(m.text.strip())
        conn = sqlite3.connect(DB_NAME)
        c = conn.cursor()
        c.execute("UPDATE users SET bots_limit = bots_limit + 1 WHERE user_id=?", (uid,))
        conn.commit()
        conn.close()
        main_bot.send_message(OWNER_ID, f"✅ تم السماح للمستخدم {uid} بصنع بوت إضافي")
    except:
        main_bot.send_message(OWNER_ID, "❌ خطأ في الإدخال")

def block_user_step(m):
    try:
        uid = int(m.text.strip())
        conn = sqlite3.connect(DB_NAME)
        c = conn.cursor()
        c.execute("UPDATE users SET can_create = 0 WHERE user_id=?", (uid,))
        conn.commit()
        conn.close()
        main_bot.send_message(OWNER_ID, f"✅ تم منع المستخدم {uid} من صنع البوتات")
    except:
        main_bot.send_message(OWNER_ID, "❌ خطأ")

def broadcast_step(m):
    text = m.text
    conn = sqlite3.connect(DB_NAME)
    c = conn.cursor()
    c.execute("SELECT user_id FROM users")
    users = c.fetchall()
    conn.close()
    count = 0
    for (uid,) in users:
        try:
            main_bot.send_message(uid, f"📢 رسالة من المالك:\n{text}")
            count += 1
        except:
            pass
    main_bot.send_message(OWNER_ID, f"✅ تم إرسال الرسالة إلى {count} مستخدم.")

if __name__ == "__main__":
