import os
import telebot
import subprocess
import tempfile
from datetime import datetime
from gtts import gTTS
from PIL import Image, ImageDraw, ImageFont

BOT_TOKEN = os.environ.get("BOT_TOKEN")
if not BOT_TOKEN:
    raise Exception("BOT_TOKEN not set")

bot = telebot.TeleBot(BOT_TOKEN)

def create_image_with_text(text, output_image):
    """إنشاء صورة واحدة تحتوي على النص"""
    width, height = 1280, 720
    img = Image.new('RGB', (width, height), color=(20, 30, 80))
    draw = ImageDraw.Draw(img)
    try:
        font = ImageFont.truetype("/usr/share/fonts/truetype/dejavu/DejaVuSans.ttf", 50)
    except:
        font = ImageFont.load_default()
    
    # تقسيم النص إلى أسطر
    lines = []
    words = text.split()
    line = ""
    for w in words:
        test_line = line + " " + w if line else w
        if len(test_line) <= 35:
            line = test_line
        else:
            lines.append(line)
            line = w
    if line:
        lines.append(line)
    
    y = 250
    for l in lines:
        draw.text((100, y), l, fill=(255,255,255), font=font)
        y += 70
    img.save(output_image)

def text_to_video_simple(text, output_video):
    """تحويل النص إلى فيديو (صورة + صوت) باستخدام ffmpeg"""
    with tempfile.TemporaryDirectory() as tmpdir:
        img_path = os.path.join(tmpdir, "slide.png")
        audio_path = os.path.join(tmpdir, "audio.mp3")
        
        # إنشاء الصورة
        create_image_with_text(text, img_path)
        
        # إنشاء الصوت
        tts = gTTS(text=text, lang='ar', slow=False)
        tts.save(audio_path)
        
        # دمج الصورة والصوت باستخدام ffmpeg
        cmd = [
            'ffmpeg', '-y',
            '-loop', '1',
            '-i', img_path,
            '-i', audio_path,
            '-c:v', 'libx264',
            '-tune', 'stillimage',
            '-c:a', 'aac',
            '-b:a', '192k',
            '-pix_fmt', 'yuv420p',
            '-shortest',
            output_video
        ]
        subprocess.run(cmd, check=True, capture_output=True)
    return output_video

@bot.message_handler(commands=['start'])
def start_cmd(message):
    bot.send_message(message.chat.id,
        "🎥 أرسل لي نصاً (حد أقصى 200 حرف) وسأحوله إلى فيديو تعليمي.\n"
        "مثال: أرسل 'مرحباً، هذا فيديو تجريبي'")

@bot.message_handler(func=lambda m: True)
def handle_text(message):
    text = message.text.strip()
    if len(text) > 200:
        bot.reply_to(message, "❌ النص طويل جداً. الرجاء إرسال نص أقل من 200 حرف.")
        return
    if len(text) < 20:
        bot.reply_to(message, "❌ النص قصير جداً. أرسل نصاً أطول (20 حرفاً على الأقل).")
        return
    
    msg = bot.reply_to(message, "⏳ جاري تحويل النص إلى فيديو... (قد يستغرق 10-20 ثانية)")
    try:
        out_file = f"video_{datetime.now().strftime('%Y%m%d_%H%M%S')}.mp4"
        text_to_video_simple(text, out_file)
        with open(out_file, 'rb') as f:
            bot.send_video(message.chat.id, f, caption="✅ تم إنشاء الفيديو!", supports_streaming=True)
        os.remove(out_file)
    except Exception as e:
        bot.edit_message_text(f"❌ خطأ: {str(e)[:200]}", message.chat.id, msg.message_id)

if __name__ == "__main__":
    print("✅ البوت يعمل...")
    bot.remove_webhook()
    bot.infinity_polling()
