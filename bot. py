import os
import telebot
import tempfile
import subprocess
from datetime import datetime
from gtts import gTTS
from PIL import Image, ImageDraw, ImageFont

BOT_TOKEN = os.environ.get("BOT_TOKEN")
if not BOT_TOKEN:
    raise Exception("BOT_TOKEN not set")

bot = telebot.TeleBot(BOT_TOKEN)

def create_image(text, output_path):
    """إنشاء صورة بخلفية ونص"""
    img = Image.new('RGB', (1280, 720), color=(25, 45, 85))
    draw = ImageDraw.Draw(img)
    try:
        font = ImageFont.truetype("/usr/share/fonts/truetype/dejavu/DejaVuSans.ttf", 48)
    except:
        font = ImageFont.load_default()
    
    # تقسيم النص لأسطر
    lines = []
    words = text.split()
    line = ""
    for w in words:
        if len(line + " " + w) <= 35:
            line += " " + w if line else w
        else:
            lines.append(line)
            line = w
    if line:
        lines.append(line)
    
    y = 250
    for l in lines:
        draw.text((100, y), l, fill=(255,255,255), font=font)
        y += 70
    
    img.save(output_path)

def text_to_video(text, output_video):
    """تحويل النص إلى فيديو (صورة ثابتة + صوت)"""
    with tempfile.TemporaryDirectory() as tmp:
        img_path = os.path.join(tmp, "slide.png")
        audio_path = os.path.join(tmp, "audio.mp3")
        
        create_image(text, img_path)
        tts = gTTS(text=text[:2000], lang='ar', slow=False)
        tts.save(audio_path)
        
        # دمج الصورة والصوت باستخدام ffmpeg
        cmd = [
            'ffmpeg', '-y',
            '-loop', '1',
            '-i', img_path,
            '-i', audio_path,
            '-c:v', 'libx264',
            '-tune', 'stillimage',
            '-c:a', 'aac',
            '-b:a', '192k',
            '-pix_fmt', 'yuv420p',
            '-shortest',
            output_video
        ]
        subprocess.run(cmd, check=True, capture_output=True)
    return output_video

@bot.message_handler(commands=['start'])
def start(message):
    bot.send_message(message.chat.id,
        "🎥 أرسل لي نصاً أو ملف .txt وسأحوله إلى فيديو.\n\n"
        "الحد الأقصى للنص: 1000 حرف (لضمان السرعة).")

@bot.message_handler(content_types=['text'])
def handle_text(message):
    text = message.text.strip()
    if len(text) > 1000:
        bot.reply_to(message, "❌ النص طويل جداً (الحد 1000 حرف).")
        return
    if len(text) < 30:
        bot.reply_to(message, "❌ النص قصير جداً (30 حرفاً على الأقل).")
        return
    
    msg = bot.reply_to(message, "⏳ جاري تحويل النص إلى فيديو...")
    try:
        out_file = f"video_{datetime.now().strftime('%Y%m%d_%H%M%S')}.mp4"
        text_to_video(text, out_file)
        with open(out_file, 'rb') as f:
            bot.send_video(message.chat.id, f, caption="✅ تم!", supports_streaming=True)
        os.remove(out_file)
    except Exception as e:
