# ========== قاعدة البيانات ==========
def init_db():
    conn = sqlite3.connect(DB_NAME)
    c = conn.cursor()
    c.execute('''CREATE TABLE IF NOT EXISTS users (
        user_id INTEGER PRIMARY KEY,
        can_create INTEGER DEFAULT 1,
        bots_limit INTEGER DEFAULT 1,
        created_bots TEXT DEFAULT '[]'
    )''')
    c.execute('''CREATE TABLE IF NOT EXISTS bots (
        token TEXT PRIMARY KEY,
        owner_id INTEGER,
        username TEXT,
        created_at TEXT
    )''')
    c.execute('''CREATE TABLE IF NOT EXISTS config (
        key TEXT PRIMARY KEY,
        value TEXT
    )''')
    c.execute("INSERT OR IGNORE INTO users (user_id, can_create, bots_limit) VALUES (?,?,?)", (OWNER_ID, 1, 999))
    conn.commit()
    conn.close()

init_db()

def get_channel():
    conn = sqlite3.connect(DB_NAME)
    c = conn.cursor()
    c.execute("SELECT value FROM config WHERE key='channel_link'")
    link = c.fetchone()
    c.execute("SELECT value FROM config WHERE key='channel_username'")
    uname = c.fetchone()
    conn.close()
    return {"link": link[0] if link else "", "username": uname[0] if uname else ""}

def set_channel(link, username):
    conn = sqlite3.connect(DB_NAME)
    c = conn.cursor()
    c.execute("REPLACE INTO config (key,value) VALUES (?,?)", ("channel_link", link))
    c.execute("REPLACE INTO config (key,value) VALUES (?,?)", ("channel_username", username))
    conn.commit()
    conn.close()

def get_user(user_id):
    conn = sqlite3.connect(DB_NAME)
    c = conn.cursor()
    c.execute("SELECT can_create, bots_limit, created_bots FROM users WHERE user_id=?", (user_id,))
    row = c.fetchone()
    conn.close()
    if row:
        return {"can_create": row[0], "bots_limit": row[1], "created_bots": json.loads(row[2])}
    return None

def create_user(user_id):
    conn = sqlite3.connect(DB_NAME)
    c = conn.cursor()
    c.execute("INSERT OR IGNORE INTO users (user_id, can_create, bots_limit, created_bots) VALUES (?,?,?,?)",
              (user_id, 1, 1, json.dumps([])))
    conn.commit()
    conn.close()

def add_bot(user_id, token, username):
    user = get_user(user_id)
    if not user:
        create_user(user_id)
        user = get_user(user_id)
    bots = user["created_bots"]
    bots.append({"token": token, "username": username})
    conn = sqlite3.connect(DB_NAME)
    c = conn.cursor()
    c.execute("UPDATE users SET created_bots=? WHERE user_id=?", (json.dumps(bots), user_id))
    c.execute("INSERT OR REPLACE INTO bots (token, owner_id, username, created_at) VALUES (?,?,?,?)",
              (token, user_id, username, datetime.now().isoformat()))
    conn.commit()
    conn.close()

def is_subscribed(user_id, channel_username):
    if not channel_username:
        return True
    try:
        member = main_bot.get_chat_member(f"@{channel_username}", user_id)
        return member.status in ["member", "administrator", "creator"]
    except:
        return False

