import os
import telebot
from telebot.types import InlineKeyboardMarkup, InlineKeyboardButton
import json
import re
from datetime import datetime

BOT_TOKEN = os.environ.get("BOT_TOKEN")
if not BOT_TOKEN:
    raise Exception("BOT_TOKEN not set")

bot = telebot.TeleBot(BOT_TOKEN)

OWNER_ID = 7021542402  # اتركه كما هو أو غيره
DATA_FILE = "users.json"

def load_data():
    if os.path.exists(DATA_FILE):
        with open(DATA_FILE, 'r') as f:
            return json.load(f)
    return {}

def save_data(data):
    with open(DATA_FILE, 'w') as f:
        json.dump(data, f)

# توليد كود بوت ابن (بسيط ويعمل)
def generate_child_bot_code(token, username, owner_username, channel_link):
    return f'''
import os
import telebot
from telebot.types import ReplyKeyboardMarkup, KeyboardButton, InlineKeyboardMarkup, InlineKeyboardButton

TOKEN = "{token}"
bot = telebot.TeleBot(TOKEN)

OWNER = "{owner_username}"
CHANNEL = "{channel_link}"

def main_menu():
    markup = ReplyKeyboardMarkup(resize_keyboard=True)
    markup.add(KeyboardButton("📢 القناة"), KeyboardButton("👤 المطور"))
    markup.add(KeyboardButton("➕ إضافة زر"), KeyboardButton("🗑️ حذف زر"))
    markup.add(KeyboardButton("📋 عرض الأزرار"))
    return markup

user_buttons = []  # قائمة الأزرار المخصصة

@bot.message_handler(commands=['start'])
def start(message):
    bot.send_message(message.chat.id, f"مرحباً بك في البوت @{username}!\\nاستخدم الأزرار أدناه.", reply_markup=main_menu())

@bot.message_handler(func=lambda m: m.text == "📢 القناة")
def channel_btn(message):
    bot.send_message(message.chat.id, f"قناتنا: {CHANNEL}")

@bot.message_handler(func=lambda m: m.text == "👤 المطور")
def owner_btn(message):
    bot.send_message(message.chat.id, f"المطور: @{OWNER}")

@bot.message_handler(func=lambda m: m.text == "➕ إضافة زر")
def add_btn(message):
    msg = bot.send_message(message.chat.id, "أرسل النص الذي سيظهر على الزر:")
    bot.register_next_step_handler(msg, get_btn_text)

def get_btn_text(message):
    text = message.text
    msg = bot.send_message(message.chat.id, "أرسل الرد الذي سيرسله البوت عند الضغط:")
    bot.register_next_step_handler(msg, lambda m: save_btn(m, text))

def save_btn(message, btn_text):
    reply = message.text
    user_buttons.append({{"text": btn_text, "reply": reply}})
    bot.send_message(message.chat.id, f"✅ تم إضافة الزر: {btn_text}")

@bot.message_handler(func=lambda m: m.text == "🗑️ حذف زر")
def del_btn(message):
    if not user_buttons:
        bot.send_message(message.chat.id, "لا توجد أزرار لحذفها.")
        return
    markup = InlineKeyboardMarkup()
    for btn in user_buttons:
        markup.add(InlineKeyboardButton(btn["text"], callback_data=f"del_{{btn['text']}}"))
    bot.send_message(message.chat.id, "اختر الزر لحذفه:", reply_markup=markup)

@bot.callback_query_handler(func=lambda call: call.data.startswith("del_"))
def delete_callback(call):
    btn_text = call.data.split("_")[1]
    global user_buttons
    user_buttons = [b for b in user_buttons if b["text"] != btn_text]
    bot.answer_callback_query(call.id, "تم الحذف")
    bot.edit_message_reply_markup(call.message.chat.id, call.message.message_id, reply_markup=None)

@bot.message_handler(func=lambda m: m.text == "📋 عرض الأزرار")
def list_btns(message):
    if not user_buttons:
        bot.send_message(message.chat.id, "لا توجد أزرار مخصصة.")
        return
    text = "الأزرار المضافة:\\n"
    for btn in user_buttons:
        text += f"- {btn['text']} -> {btn['reply']}\\n"
    bot.send_message(message.chat.id, text)

@bot.message_handler(func=lambda m: True)
def handle_custom_buttons(message):
    for btn in user_buttons:
        if message.text == btn["text"]:
            bot.send_message(message.chat.id, btn["reply"])
            return

print("✅ البوت يعمل...")
bot.infinity_polling()
'''

@bot.message_handler(commands=['start'])
def start_cmd(message):
    markup = InlineKeyboardMarkup()
    markup.add(InlineKeyboardButton("➕ صنع بوت جديد", callback_data="new_bot"))
    markup.add(InlineKeyboardButton("📋 بوتاتي", callback_data="my_bots"))
    if message.chat.id == OWNER_ID:
        markup.add(InlineKeyboardButton("⚙️ إعدادات", callback_data="admin"))
    bot.send_message(message.chat.id, "🤖 مرحباً! أنا مصنع البوتات.\nأرسل توكن بوتك الجديد.", reply_markup=markup)

@bot.callback_query_handler(func=lambda call: True)
def callback_handler(call):
    if call.data == "new_bot":
        bot.send_message(call.message.chat.id, "🔑 أرسل توكن البوت (من @BotFather):")
        bot.register_next_step_handler(call.message, process_token)
    elif call.data == "my_bots":
        data = load_data()
        user_id = str(call.message.chat.id)
        bots = data.get(user_id, [])
        if not bots:
            bot.send_message(call.message.chat.id, "📭 ليس لديك أي بوتات بعد.")
        else:
            txt = "📋 بوتاتك:\n" + "\n".join([f"- @{b['username']}" for b in bots])
            bot.send_message(call.message.chat.id, txt)
    elif call.data == "admin" and call.message.chat.id == OWNER_ID:
        bot.send_message(OWNER_ID, "🔧 لوحة تحكم المالك:\nلا توجد إعدادات متاحة حالياً.")

def process_token(message):
    token = message.text.strip().replace(" ", "")
    user_id = message.chat.id
    try:
        test = telebot.TeleBot(token)
        me = test.get_me()
        username = me.username
        # حفظ البوت
        data = load_data()
        user_bots = data.get(str(user_id), [])
        user_bots.append({"username": username, "token": token})
        data[str(user_id)] = user_bots
        save_data(data)
        # توليد الكود
        owner_username = "zakros0_onlinebot"
        channel_link = "https://t.me/KAR_XNiyzokyyy"
        code = generate_child_bot_code(token, username, owner_username, channel_link)
        # إرسال الكود كملف
        with open(f"{username}_bot.py", "w") as f:
            f.write(code)
        with open(f"{username}_bot.py", "rb") as f:
            bot.send_document(user_id, f, caption=f"✅ تم إنشاء البوت @{username}\nقم بتحميل هذا الملف ورفعه على Heroku.")
        os.remove(f"{username}_bot.py")
    except Exception as e:
        bot.send_message(user_id, f"❌ فشل: {str(e)[:200]}")

if __name__ == "__main__":
    print("✅ البوت الرئيسي يعمل...")
    bot.remove_webhook()
    bot.infinity_polling()
