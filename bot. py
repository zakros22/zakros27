import os
import telebot
import tempfile
import subprocess
import re
from datetime import datetime
from gtts import gTTS
from PIL import Image, ImageDraw, ImageFont
import PyPDF2
import docx

BOT_TOKEN = os.environ.get("BOT_TOKEN")
if not BOT_TOKEN:
    raise Exception("BOT_TOKEN not set")

bot = telebot.TeleBot(BOT_TOKEN)

def extract_text(file_path):
    """استخراج النص من ملف (txt, pdf, docx)"""
    ext = os.path.splitext(file_path)[1].lower()
    if ext == '.txt':
        with open(file_path, 'r', encoding='utf-8') as f:
            return f.read()
    elif ext == '.pdf':
        text = ""
        with open(file_path, 'rb') as f:
            reader = PyPDF2.PdfReader(f)
            for page in reader.pages:
                text += page.extract_text()
        return text
    elif ext == '.docx':
        doc = docx.Document(file_path)
        return "\n".join([para.text for para in doc.paragraphs])
    else:
        raise Exception("نوع ملف غير مدعوم (يدعم: txt, pdf, docx)")

def split_into_scenes(text, max_len=300):
    """تقسيم النص إلى مشاهد (كل مشهد 300 حرف كحد أقصى)"""
    sentences = re.split(r'(?<=[.!?؟]) +', text)
    scenes = []
    current = ""
    for sent in sentences:
        if len(current) + len(sent) + 1 <= max_len:
            current += " " + sent if current else sent
        else:
            if current:
                scenes.append(current)
            current = sent
    if current:
        scenes.append(current)
    if not scenes:
        scenes = [text[:max_len]]
    return scenes[:12]  # حد أقصى 12 مشهداً لضمان السرعة

def create_scene_image(text, index, output_path):
    """إنشاء صورة مشهد بخلفية جذابة ونص"""
    width, height = 1280, 720
    img = Image.new('RGB', (width, height), color=(20, 30, 60))  # خلفية زرقاء داكنة
    draw = ImageDraw.Draw(img)
    try:
        font = ImageFont.truetype("/usr/share/fonts/truetype/dejavu/DejaVuSans.ttf", 48)
    except:
        font = ImageFont.load_default()
    
    # تقسيم النص إلى أسطر (كل سطر 30 حرفاً)
    words = text.split()
    lines = []
    line = ""
    for w in words:
        if len(line + " " + w) <= 35:
            line += " " + w if line else w
        else:
            lines.append(line)
            line = w
    if line:
        lines.append(line)
    
    y = 250
    for l in lines:
        draw.text((100, y), l, fill=(255, 255, 255), font=font)
        y += 70
    
    # إضافة رقم المشهد
    draw.text((1150, 650), f"{index}", fill=(200, 200, 200), font=font)
    img.save(output_path)

def text_to_video(text, output_video):
    """تحويل النص إلى فيديو (صور + صوت)"""
    scenes = split_into_scenes(text)
    if not scenes:
        raise Exception("لا يوجد نص صالح للتحويل")
    
    with tempfile.TemporaryDirectory() as tmpdir:
        # إنشاء صور المشاهد
        scene_images = []
        for i, scene in enumerate(scenes):
            img_path = os.path.join(tmpdir, f"scene_{i}.png")
            create_scene_image(scene, i+1, img_path)
            scene_images.append(img_path)
        
        # تحويل النص الكامل إلى صوت (gTTS)
        full_text = " ".join(scenes)
        audio_path = os.path.join(tmpdir, "audio.mp3")
        tts = gTTS(text=full_text[:3000], lang='ar', slow=False)
        tts.save(audio_path)
        
        # حساب مدة الصوت
        result = subprocess.run(['ffprobe', '-v', 'error', '-show_entries', 'format=duration', '-of', 'default=noprint_wrappers=1:nokey=1', audio_path], capture_output=True, text=True)
        audio_duration = float(result.stdout.strip())
        
        # توزيع المدة على المشاهد
        duration_per_scene = audio_duration / len(scene_images)
        
        # إنشاء ملف concat لـ ffmpeg
        concat_file = os.path.join(tmpdir, "concat.txt")
        with open(concat_file, 'w') as f:
            for img in scene_images:
                f.write(f"file '{img}'\nduration {duration_per_scene}\n")
        with open(concat_file, 'a') as f:
            f.write(f"file '{scene_images[-1]}'\n")
        
        # دمج الصور والصوت في فيديو
        cmd = [
            'ffmpeg', '-y',
            '-f', 'concat',
            '-safe', '0',
            '-i', concat_file,
            '-i', audio_path,
            '-c:v', 'libx264',
            '-pix_fmt', 'yuv420p',
            '-c:a', 'aac',
            '-shortest',
            output_video
        ]
        subprocess.run(cmd, check=True, capture_output=True)
    
    return output_video

@bot.message_handler(commands=['start'])
def start_cmd(message):
    bot.send_message(message.chat.id,
        "🎥 *بوت تحويل النصوص إلى فيديو تعليمي*\n\n"
        "أرسل لي ملفاً نصياً (txt, pdf, docx) وسأقوم بتحليله وتحويله إلى فيديو احترافي.\n\n"
        "📌 *ملاحظات:*\n"
        "- النص يجب ألا يزيد عن 2500 حرف (لضمان سرعة المعالجة).\n"
        "- الفيديو الناتج سيكون بصيغة MP4 مع شرائح نصية وصوت.\n"
        "- قد تستغرق المعالجة 30-60 ثانية حسب طول النص.",
        parse_mode="Markdown")

@bot.message_handler(content_types=['document'])
def handle_doc(message):
    try:
        # تحميل الملف
        file_info = bot.get_file(message.document.file_id)
        downloaded = bot.download_file(file_info.file_path)
        with tempfile.NamedTemporaryFile(delete=False, suffix=os.path.splitext(message.document.file_name)[1]) as tmp:
            tmp.write(downloaded)
            tmp_path = tmp.name
        
        # استخراج النص
        text = extract_text(tmp_path)
        os.unlink(tmp_path)
        
        if len(text) > 2500:
            bot.reply_to(message, "❌ النص في الملف طويل جداً (الحد الأقصى 2500 حرف).")
            return
        if len(text) < 50:
            bot.reply_to(message, "❌ النص قصير جداً (يحتاج على الأقل 50 حرفاً).")
            return
        
        msg = bot.reply_to(message, "⏳ جاري تحليل النص وتحويله إلى فيديو... قد يستغرق دقيقة.")
        out_file = f"video_{datetime.now().strftime('%Y%m%d_%H%M%S')}.mp4"
        text_to_video(text, out_file)
        
        with open(out_file, 'rb') as f:
            bot.send_video(message.chat.id, f, caption="✅ تم تحويل الملف النصي إلى فيديو تعليمي بنجاح!", supports_streaming=True)
        os.remove(out_file)
        
    except Exception as e:
        bot.reply_to(message, f"❌ حدث خطأ: {str(e)[:200]}")

@bot.message_handler(func=lambda m: m.text and not m.text.startswith('/'))
def handle_text(message):
    text = message.text.strip()
    if len(text) > 2000:
        bot.reply_to(message, "❌ النص طويل جداً (الحد الأقصى 2000 حرف).")
        return
    if len(text) < 50:
        bot.reply_to(message, "❌ النص قصير جداً (يحتاج 50 حرفاً على الأقل).")
        return
    msg = bot.reply_to(message, "⏳ جاري تحويل النص إلى فيديو...")
    try:
        out_file = f"video_{datetime.now().strftime('%Y%m%d_%H%M%S')}.mp4"
        text_to_video(text, out_file)
        with open(out_file, 'rb') as f:
            bot.send_video(message.chat.id, f, caption="✅ تم إنشاء الفيديو!", supports_streaming=True)
        os.remove(out_file)
    except Exception as e:
        bot.edit_message_text(f"❌ خطأ: {str(e)[:200]}", message.chat.id, msg.message_id)

if __name__ == "__main__":
    print("✅ بوت تحليل النصوص وإنتاج الفيديو يعمل...")
    bot.remove_webhook()
    bot.infinity_polling()
